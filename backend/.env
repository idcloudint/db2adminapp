# Server Configuration
PORT=3001
NODE_ENV=development

# DB2 Configuration
DB2_NAMESPACE=db2-community
DB2_POD_LABEL=app=db2
DB2_SERVICE=db2-service
DB2_PORT=50000
DB2_DATABASE=SAMPLE
DB2_USER=db2inst1
DB2_PASSWORD=db2inst1-pwd

# OpenShift Configuration
# Leave empty to use in-cluster config when running in OpenShift
# Set to path of kubeconfig file for local development
KUBECONFIG_PATH=

# Collection Intervals (milliseconds)
COLLECTION_INTERVAL_POD=60000
COLLECTION_INTERVAL_DB2=60000
COLLECTION_INTERVAL_STORAGE=300000
COLLECTION_INTERVAL_BACKUP=300000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS
CORS_ORIGIN=http://localhost:3000

# WebSocket
WS_HEARTBEAT_INTERVAL=30000